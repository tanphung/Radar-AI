# Root env — used by deploy/cron scripts. Frontend has its own .env.example.

# GenLayer network: testnet-bradbury | testnet-asimov | localnet
GENLAYER_NETWORK=testnet-bradbury
GENLAYER_RPC=

# Set after `genlayer deploy` writes back
CONTRACT_ADDRESS=

# Wallet that signs cron monitor_batch calls (fund with testnet GEN)
CRON_PRIVATE_KEY=
