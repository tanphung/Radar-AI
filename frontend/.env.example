# --- GenLayer (Phase 9) ---
NEXT_PUBLIC_GENLAYER_NETWORK=testnet-bradbury
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Set to 1 during dev to keep the mock contract client even when address is set
NEXT_PUBLIC_MOCK_CONTRACT=1

# --- SIWE / JWT session (Phase 6) ---
# Domain the SIWE message asserts the user is signing for (no protocol).
# Must match the host the browser is on or siwe.verify() rejects.
SIWE_DOMAIN=localhost:3000

# Secret for HS256-signed session cookies. Generate with
#   openssl rand -base64 32
# In dev the code falls back to a placeholder if missing; in prod set this.
JWT_SECRET=

# --- Supabase (Phase 6) ---
# Leave blank to fall back to an in-memory watchlist store (lost on restart).
# Set both to persist real watchlists. Service key is server-only — never
# expose it via a NEXT_PUBLIC_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
